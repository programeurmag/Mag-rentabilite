# Copier ce fichier vers ".env" et remplir les vraies valeurs.
# Le fichier ".env" ne doit jamais être commité (voir .gitignore).

JOBBER_CLIENT_ID=
JOBBER_CLIENT_SECRET=
SLACK_WEBHOOK_URL=

# Phase 2 (optionnel) — si absente ou invalide, le rapport part sans la section analyse IA
ANTHROPIC_API_KEY=

# Module 3 (Rapport de chantier) + Module 4 (Dashboard) — contenu JSON complet de
# la clé du compte de service Google (une seule ligne). Scope : spreadsheets
# (lecture-écriture, voir SPEC_module_dashboard_MAG.md section 1) — le compte de
# service doit être partagé en Lecteur sur le Sheets de réponses du Form et en
# Éditeur sur MAG_Dashboard_Data. Voir SPEC_module_rapport_chantier_MAG.md section 2.
GOOGLE_SERVICE_ACCOUNT_JSON=

# Module 3 — webhook Slack du canal de production (rappel matinal). Peut être
# le même que SLACK_WEBHOOK_URL ci-dessus (à la discrétion de Justin) ; si
# absent, generer_rappel_matin.py retombe sur SLACK_WEBHOOK_URL.
SLACK_WEBHOOK_URL_PRODUCTION=
